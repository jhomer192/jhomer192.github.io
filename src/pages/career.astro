---
import Base from '../layouts/Base.astro';

const projects = [
  {
    title: 'US Marine Corps: Workforce Management Suite',
    description:
      'Led multiple applications across the Marine Corps workforce ecosystem, including automated tasking, HR management, and housing optimization. Served as workstream lead on multiple phases, architecting reusable packages shared across the portfolio so each new project inherits tested, production-ready code from prior engagements.',
  },
  {
    title: 'US Marine Corps: MEF Workforce Planning',
    description:
      'Led end-to-end delivery of a workforce planning application for a Marine Expeditionary Force, working from a 108-page product specification. Designed the integration pipeline between data science optimization models and the application layer, including scheduling views and readiness dashboards used by commanders. Led on-site workshops with Marine Corps stakeholders across multiple command levels. Delivered on schedule, resulting in a follow-on engagement at expanded scope.',
  },
  {
    title: 'Data Asset Management Framework',
    description:
      'Designed a data ingestion framework that reduces the effort to connect an external data source to a C3 application to roughly half a day of developer time, driven by a natural language prompt. The UI is fully dynamic, requiring minimal backend work per new data source. Built as a reusable package so any project can adopt it with no frontend changes.',
  },
  {
    title: 'AI-Powered Legal Document Translation',
    description:
      'Built an automated document translation system for high-stakes legal use under a hard deadline. Uses a multi-agent adversarial architecture: a neural machine translation first pass, a critic agent that scores output across five quality dimensions, and an arbiter agent that merges results with full provenance tracking. Replaced what would have required significant spend on outside professional services with an in-house solution meeting the same quality bar.',
  },
  {
    title: 'Enterprise AI Agent Suite',
    description:
      'Built a suite of production AI agents now used across sales, legal, and finance functions. Includes a pre-proposal qualification agent that maps AI applications across verticals to help sales teams assess fit before pitching, a proposal generation agent, and an expense analysis agent for finance teams. Authored the original vision document for AI-assisted development tooling that preceded and shaped the formal initiative.',
  },
  {
    title: 'Platform Reliability',
    description:
      'Organized field team contribution to a company-wide platform stability initiative. Built a script to trace system actions preceding crash events, identifying the patterns driving instability. Published internal guides on crash triage methodology. Contributed to taking daily crash frequency across the internal developer community down 94%.',
  },
];

const prior = [
  { label: 'Software Engineer Intern, The Action Network', detail: 'Summer 2021' },
  { label: 'Teaching Assistant, Virginia Tech', detail: 'Spring 2023' },
  { label: 'BS Computer Science, Virginia Tech', detail: '2019 to 2023' },
];
---

<Base title="Career - Jack Homer" description="Jack Homer's career at C3 AI - forward deployed engineering, federal and enterprise delivery, and platform work.">
  <div class="mx-auto max-w-4xl px-6 py-16">

    <div class="mb-14">
      <h1 class="text-4xl font-bold mb-3 bg-gradient-to-r from-[var(--accent)] via-[var(--accent-2)] to-[var(--accent-3)] bg-clip-text text-transparent">
        Forward Deployed Engineer at{' '}
        <a
          href="https://c3.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-4 decoration-accent hover:opacity-80 transition-opacity"
        >C3 AI</a>
      </h1>
      <p class="text-text-muted text-base mb-5">
        Redwood City, California.
      </p>
      <p class="text-text text-base leading-relaxed max-w-2xl">
        I lead end-to-end delivery of applications on C3's platform for federal and enterprise customers,
        and I build reusable packages adopted across the portfolio so each new engagement ships faster on a tested foundation.
      </p>
    </div>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-text mb-8">Selected Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <div class="rounded-xl border border-border bg-surface p-6 flex flex-col gap-3 transition-all duration-200 hover:border-accent/40 hover:bg-surface-hover hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/10">
            <h3 class="text-base font-semibold text-text">{project.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{project.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-text-dim uppercase tracking-widest mb-4">Prior</h2>
      <ul class="flex flex-col gap-2">
        {prior.map((item) => (
          <li class="flex items-baseline gap-3 text-sm text-text-dim">
            <span class="text-text-muted">{item.label}</span>
            <span class="text-text-dim">{item.detail}</span>
          </li>
        ))}
      </ul>
    </section>

  </div>
</Base>
