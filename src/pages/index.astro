---
import Base from '../layouts/Base.astro';
import GameOfLife from '../components/GameOfLife.astro';
---

<Base title="Jack Homer - Software Engineer" description="Jack Homer - Software Engineer at C3 AI, Virginia Tech CS grad. Building software and side projects in Menlo Park, CA.">
  <!-- Hero with Game of Life background -->
  <section class="relative mx-auto max-w-5xl px-6 pt-20 pb-16 overflow-hidden">
    <GameOfLife />
    <div class="relative z-10">
      <h1 class="text-5xl font-bold bg-gradient-to-r from-[var(--accent)] via-[var(--accent-2)] to-[var(--accent-3)] bg-clip-text text-transparent">
        Jack Homer
      </h1>
      <p class="mt-4 text-xl text-text-muted max-w-xl">
        Forward Deployed Engineer at C3 AI. Building software, building businesses.
      </p>
      <p class="mt-4 text-text-dim max-w-2xl leading-relaxed">
        Based in Menlo Park, CA. CS grad from Virginia Tech (2023). Full-stack
        engineer by day, building websites and digital tools for local businesses
        on the side.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      <a
        href="/projects"
        class="group rounded-2xl border border-accent/50 bg-surface p-6 transition-all duration-200 hover:bg-surface-hover hover:-translate-y-1 shadow-lg shadow-accent/10 hover:shadow-xl hover:shadow-accent/20"
      >
        <div class="mb-3 text-2xl">&#x2692;&#xFE0F;</div>
        <h2 class="mb-2 text-xl font-bold text-text group-hover:text-accent transition-colors">
          Side projects
        </h2>
        <p class="text-sm text-text-muted leading-relaxed">
          Wikipedia game solvers, Conway's Game of Life, birthday paradox visualizers, and more.
        </p>
        <span class="mt-4 inline-block text-xs text-accent group-hover:text-accent-hover">
          Browse projects &rarr;
        </span>
      </a>

      <a
        href="/career"
        class="group rounded-2xl border border-border bg-surface p-6 transition-all duration-200 hover:border-accent/50 hover:bg-surface-hover hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/10"
      >
        <div class="mb-3 text-2xl">&#x1F4BC;</div>
        <h2 class="mb-2 text-lg font-semibold text-text group-hover:text-accent transition-colors">
          Career
        </h2>
        <p class="text-sm text-text-muted leading-relaxed">
          Forward Deployed Engineer at C3 AI, Virginia Tech CS alum, and past intern at The Action Network.
        </p>
        <span class="mt-4 inline-block text-xs text-accent group-hover:text-accent-hover">
          View timeline &rarr;
        </span>
      </a>

      <a
        href="/business"
        class="group rounded-2xl border border-border bg-surface p-6 transition-all duration-200 hover:border-accent/50 hover:bg-surface-hover hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/10"
      >
        <div class="mb-3 text-2xl">&#x1F3EA;</div>
        <h2 class="mb-2 text-lg font-semibold text-text group-hover:text-accent transition-colors">
          Business
        </h2>
        <p class="text-sm text-text-muted leading-relaxed">
          Helping local businesses get online fast - websites, email, Google reviews, and domain management.
        </p>
        <span class="mt-4 inline-block text-xs text-accent group-hover:text-accent-hover">
          Learn more &rarr;
        </span>
      </a>
    </div>
  </section>
</Base>
