---
import Base from '../layouts/Base.astro';
import GameOfLife from '../components/GameOfLife.astro';
---

<Base title="Jack Homer" description="Jack Homer - Forward Deployed Engineer at C3 AI, developer, and entrepreneur based in Menlo Park.">
  <!-- Hero with Game of Life canvas background -->
  <section class="relative mx-auto max-w-5xl px-6 pt-20 pb-16 overflow-hidden">
    <GameOfLife />
    <div class="relative z-10">
      <div class="flex items-center gap-5 mb-4">
        <img
          src="/me.jpg"
          alt="Jack Homer"
          width="88"
          height="88"
          class="rounded-full w-20 h-20 sm:w-22 sm:h-22 object-cover border-2 border-accent-500/70 shadow-lg shadow-accent-500/20 flex-shrink-0"
        />
        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl bg-gradient-to-r from-sky-400 via-cyan-400 to-violet-400 bg-clip-text text-transparent">
          Jack Homer
        </h1>
      </div>
      <p class="mt-4 text-xl text-slate-300 max-w-xl">
        Forward Deployed Engineer at C3 AI. Building software, building businesses.
      </p>
      <p class="mt-4 text-slate-400 max-w-2xl leading-relaxed">
        Based in Menlo Park, CA. CS grad from Virginia Tech (2023). I do full-stack
        work professionally and build side projects for fun - plus a small local
        business venture on the side.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      <a
        href="/career"
        class="group rounded-2xl border border-white/10 bg-ink-800 p-6 transition-all duration-200 hover:border-accent-500/50 hover:bg-ink-700 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-500/10"
      >
        <div class="mb-3 text-2xl">&#x1F4BC;</div>
        <h2 class="mb-2 text-lg font-semibold text-slate-100 group-hover:text-accent-400 transition-colors">
          Career
        </h2>
        <p class="text-sm text-slate-400 leading-relaxed">
          Forward Deployed Engineer at C3 AI, Virginia Tech CS alum, and past intern at The Action Network.
        </p>
        <span class="mt-4 inline-block text-xs text-accent-500 group-hover:text-accent-400">
          View timeline &rarr;
        </span>
      </a>

      <a
        href="/projects"
        class="group rounded-2xl border border-white/10 bg-ink-800 p-6 transition-all duration-200 hover:border-accent-500/50 hover:bg-ink-700 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-500/10"
      >
        <div class="mb-3 text-2xl">&#x2692;&#xFE0F;</div>
        <h2 class="mb-2 text-lg font-semibold text-slate-100 group-hover:text-accent-400 transition-colors">
          Side projects
        </h2>
        <p class="text-sm text-slate-400 leading-relaxed">
          Wikipedia game solvers, Conway's Game of Life, birthday paradox visualizers, and more.
        </p>
        <span class="mt-4 inline-block text-xs text-accent-500 group-hover:text-accent-400">
          Browse projects &rarr;
        </span>
      </a>

      <a
        href="/business"
        class="group rounded-2xl border border-white/10 bg-ink-800 p-6 transition-all duration-200 hover:border-accent-500/50 hover:bg-ink-700 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-500/10"
      >
        <div class="mb-3 text-2xl">&#x1F3EA;</div>
        <h2 class="mb-2 text-lg font-semibold text-slate-100 group-hover:text-accent-400 transition-colors">
          Business
        </h2>
        <p class="text-sm text-slate-400 leading-relaxed">
          Helping local businesses get online fast - websites, email, Google reviews, and domain management.
        </p>
        <span class="mt-4 inline-block text-xs text-accent-500 group-hover:text-accent-400">
          Learn more &rarr;
        </span>
      </a>
    </div>
  </section>
</Base>
