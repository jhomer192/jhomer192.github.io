---
import Base from '../layouts/Base.astro';

const projects = [
  {
    title: 'WikiGame',
    description: 'Daily Wikipedia racing game. Navigate from one article to another by clicking links. No search, no cheating. Shareable results, 1,826 verified challenges.',
    live: 'https://jhomer192.github.io/wikigame/',
    repo: 'https://github.com/jhomer192/wikigame',
    screenshot: '/screenshots/wikigame.webp',
  },
  {
    title: 'Connections Maker',
    description: 'Build and share your own NYT-style Connections puzzles. 16 words, 4 groups, all encoded in the URL — no account, no backend.',
    live: 'https://jhomer192.github.io/connections-maker/',
    repo: 'https://github.com/jhomer192/connections-maker',
    screenshot: '/screenshots/connections-maker.webp',
  },
  {
    title: 'Meme Generator',
    description: 'Pick from 100+ popular templates or upload your own. Impact text, draggable positioning, full-res PNG download.',
    live: 'https://jhomer192.github.io/meme-generator/',
    repo: 'https://github.com/jhomer192/meme-generator',
    screenshot: '/screenshots/meme-generator.webp',
  },
  {
    title: 'Clocktower Assistant',
    description: 'Blood on the Clocktower Storyteller tool. Night order, nominations, voting, player status, game log. Full Trouble Brewing script with custom roles.',
    live: 'https://jhomer192.github.io/clocktower/',
    repo: 'https://github.com/jhomer192/clocktower',
    screenshot: '/screenshots/clocktower.webp',
  },
  // Apartment Finder and Flight Deals hidden until real price APIs are wired up
  {
    title: 'Nuzlocke Tracker',
    description: 'Pokemon Nuzlocke challenge tracker with PokeAPI integration, 18-type coverage matrix, route encounter logging, team management, and graveyard.',
    live: 'https://jhomer192.github.io/nuzlocke-tracker/',
    repo: 'https://github.com/jhomer192/nuzlocke-tracker',
    screenshot: '/screenshots/nuzlocke-tracker.webp',
  },
  // Hotel Finder hidden until real price data is integrated
  {
    title: 'Wikipedia Game Solver',
    description: 'TF-IDF + cosine greedy walk through Wikipedia article links.',
    live: 'https://jhomer192.github.io/wikipedia-game-solver/',
    repo: 'https://github.com/jhomer192/wikipedia-game-solver',
    screenshot: '/screenshots/wikipedia-game-solver.webp',
  },
  {
    title: "Conway's Game of Life",
    description: 'Interactive React cellular automaton.',
    live: 'https://jhomer192.github.io/game-of-life/',
    repo: 'https://github.com/jhomer192/game-of-life',
    screenshot: '/screenshots/game-of-life.webp',
  },
  {
    title: 'Birthday Paradox Simulator',
    description: 'Interactive probability visualizer.',
    live: 'https://jhomer192.github.io/birthday-paradox/',
    repo: 'https://github.com/jhomer192/birthday-paradox',
    screenshot: '/screenshots/birthday-paradox.webp',
  },
  {
    title: 'Claude Telegram Bot',
    description: 'Persistent Claude Agent SDK harness running as a self-hosted Telegram bot. Long-polls Telegram, queues turns per chat, streams tool calls back live, persists session IDs in SQLite, and sandboxes itself with systemd. Built every other project on this page.',
    repo: 'https://github.com/jhomer192/claude-bot',
  },
];
---

<Base title="Side Projects - Jack Homer | Software Engineer" description="Jack Homer's side projects: Wikipedia game solver, Pokemon Nuzlocke tracker, apartment finder, flight deal watcher, meme generator, and more. React, TypeScript, and Tailwind.">
  <div class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-4xl font-bold mb-12 bg-gradient-to-r from-[var(--accent)] via-[var(--accent-2)] to-[var(--accent-3)] bg-clip-text text-transparent">Side projects</h1>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {projects.map((project) => (
        <div class="flex flex-col rounded-2xl border border-border bg-surface overflow-hidden transition-all duration-200 hover:border-accent/50 hover:bg-surface-hover hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/10">
          {project.screenshot ? (
            <a href={project.live ?? project.repo} target="_blank" rel="noopener noreferrer" class="block overflow-hidden">
              <img
                src={project.screenshot}
                alt={`${project.title} screenshot`}
                class="w-full aspect-[16/10] object-cover object-top rounded-t-2xl"
                loading="lazy"
              />
            </a>
          ) : (
            <div class="w-full aspect-[16/10] bg-surface-hover rounded-t-2xl flex items-center justify-center text-text-dim select-none">
              <span class="font-mono text-4xl opacity-40">&gt;_</span>
            </div>
          )}
          <div class="flex flex-col flex-1 p-6">
            <h2 class="text-lg font-semibold text-text mb-2">{project.title}</h2>
            <p class="text-sm text-text-muted leading-relaxed flex-1">{project.description}</p>
            <div class="mt-5 flex flex-wrap gap-4 text-sm">
              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:text-accent-hover transition-colors"
                >
                  Live &rarr;
                </a>
              )}
              <a
                href={project.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-muted hover:text-accent transition-colors"
              >
                Repo &rarr;
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>
